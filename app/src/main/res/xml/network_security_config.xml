<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for local development -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.deepseek.com</domain>
        <domain includeSubdomains="true">platform.deepseek.com</domain>
        <domain includeSubdomains="true">cdn.deepseek.com</domain>
    </domain-config>
    <!-- Default: disallow cleartext -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
